/* 黑坑列表页面 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
}

.search-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
}

.search-input .icon {
  margin-right: 10rpx;
}

.search-input .placeholder {
  color: #999;
  font-size: 28rpx;
}

.apply-btn {
  padding: 0 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.filters {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background: #2E7D32;
  color: #fff;
  border-color: #2E7D32;
}

.pond-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pond-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  position: relative;
}

.pond-card .cover {
  width: 100%;
  height: 300rpx;
}

.pond-info {
  padding: 20rpx;
}

.pond-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.pond-address {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.pond-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.pond-tags .tag {
  padding: 4rpx 12rpx;
  background: #e8f5e9;
  color: #2E7D32;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.pond-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.event-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.event-count .badge {
  background: rgba(255,82,82,0.9);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
