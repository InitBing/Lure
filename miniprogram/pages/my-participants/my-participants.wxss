/* 我的报名页面 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #2E7D32;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2E7D32;
  border-radius: 2rpx;
}

.list-scroll {
  flex: 1;
  padding: 20rpx;
}

.participant-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.event-type {
  padding: 6rpx 16rpx;
  background: #667eea;
  color: #fff;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-tag.warning {
  background: #fff3e0;
  color: #ff9800;
}

.status-tag.active {
  background: #e8f5e9;
  color: #2E7D32;
}

.status-tag.cancelled {
  background: #ffebee;
  color: #f44336;
}

.status-tag.success {
  background: #e3f2fd;
  color: #2196f3;
}

.event-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.event-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 10rpx;
}

.pay-btn, .checkin-btn, .review-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  border-radius: 4rpx;
}

.pay-btn {
  background: #ff9800;
  color: #fff;
}

.checkin-btn {
  background: #2E7D32;
  color: #fff;
}

.review-btn {
  background: #2196f3;
  color: #fff;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
