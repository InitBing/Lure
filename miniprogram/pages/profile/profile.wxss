/* 个人主页 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #1b5e20 100%);
  color: #fff;
}

.user-header .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-header .user-info {
  flex: 1;
  margin-left: 30rpx;
}

.user-header .nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-header .region,
.user-header .signature {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 4rpx;
}

.action-btns {
  display: flex;
  gap: 10rpx;
}

.follow-btn, .following-btn {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.follow-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.following-btn {
  background: rgba(255,255,255,0.1);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.stats {
  display: flex;
  background: #fff;
  margin: 20rpx;
  padding: 30rpx 0;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-right: none;
}

.stat-item .value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.stat-item .label {
  font-size: 24rpx;
  color: #999;
}

.tabs {
  display: flex;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #2E7D32;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2E7D32;
  border-radius: 2rpx;
}

.content-list {
  flex: 1;
  padding: 0 20rpx;
  overflow-y: auto;
}

.log-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding-bottom: 20rpx;
}

.log-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.log-img {
  width: 100%;
  height: 300rpx;
}

.log-info {
  padding: 16rpx;
}

.log-catch {
  font-size: 26rpx;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.log-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.log-stats {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #666;
}

.item-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding-bottom: 20rpx;
}

.item-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.item-img {
  width: 100%;
  height: 300rpx;
}

.item-info {
  padding: 16rpx;
  position: relative;
}

.item-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 30rpx;
  color: #ff5252;
  font-weight: bold;
}

.item-status {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.empty, .loading {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}
