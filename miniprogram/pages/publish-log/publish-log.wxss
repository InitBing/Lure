/* 发布作钓记录页面 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title .add-btn {
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: normal;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
}

.form-item .input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
}

.form-item .input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.form-item .picker {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.form-item .icon {
  margin-left: 10rpx;
  font-size: 32rpx;
}

.form-item .arrow {
  color: #ccc;
  font-size: 32rpx;
  margin-left: 10rpx;
}

.form-item.switch {
  justify-content: space-between;
}

.textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.catch-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.catch-item {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 16rpx;
}

.catch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.catch-index {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
}

.delete-btn, .delete-lure, .delete-photo {
  font-size: 24rpx;
  color: #ff5252;
}

.delete-lure, .delete-photo {
  font-size: 32rpx;
  padding: 0 10rpx;
}

.catch-form {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.catch-row {
  display: flex;
  gap: 10rpx;
}

.catch-row .half {
  flex: 1;
}

.lure-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.lure-item {
  display: flex;
  align-items: center;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 16rpx;
}

.lure-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.add-lure {
  text-align: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  color: #2E7D32;
  font-size: 28rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
}

.photo {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-photo {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  width: 40rpx;
  height: 40rpx;
  border-radius: 0 8rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border-radius: 8rpx;
  aspect-ratio: 1;
}

.upload-btn .icon {
  font-size: 60rpx;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.upload-btn .label {
  font-size: 24rpx;
  color: #2E7D32;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #2E7D32;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  opacity: 0.8;
}
