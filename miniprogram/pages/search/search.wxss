/* 搜索页面 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  gap: 20rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  gap: 10rpx;
}

.search-input-wrapper .icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #2E7D32;
}

.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .title {
  font-size: 28rpx;
  color: #666;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
}

.history-list, .hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item, .hot-item {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #333;
}

.result-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.result-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e0e0e0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #2E7D32;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #2E7D32;
  border-radius: 2rpx;
}

.result-list {
  flex: 1;
  padding: 20rpx;
}

.result-group {
  margin-bottom: 30rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.spot-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.spot-item .name {
  font-size: 28rpx;
  color: #333;
}

.spot-item .location {
  font-size: 24rpx;
  color: #999;
}

.log-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.log-item .thumb {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.log-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.log-info .notes {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.log-info .user {
  font-size: 24rpx;
  color: #999;
}

.item-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.item-card {
  background: #fff;
  border-radius: 8rpx;
  padding: 16rpx;
}

.item-img {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.item-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 28rpx;
  color: #ff5252;
  font-weight: bold;
}

.user-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.user-item .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.user-info {
  flex: 1;
}

.user-info .nickname {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.user-info .region {
  font-size: 24rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}
