/* 钓点详情页面 */
.container {
  padding-bottom: 120rpx;
  background: #f5f5f5;
}

.banner {
  width: 100%;
  height: 400rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.card {
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.info-card .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.info-card .location {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.info-card .location .icon {
  margin-right: 8rpx;
}

.info-card .tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.info-card .tag {
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  color: #2E7D32;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.info-card .rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-card .stars {
  font-size: 28rpx;
}

.info-card .score {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff9800;
}

.info-card .count {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title .more {
  font-size: 24rpx;
  color: #2E7D32;
  font-weight: normal;
}

.detail-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row .label {
  width: 160rpx;
  font-size: 26rpx;
  color: #999;
}

.detail-row .value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.detail-row .value.desc {
  white-space: pre-wrap;
  line-height: 1.6;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.log-item {
  display: flex;
  gap: 20rpx;
}

.log-img {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.log-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.log-user {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.log-user .avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.log-user .name {
  font-size: 24rpx;
  color: #666;
}

.log-catch {
  font-size: 24rpx;
  color: #2E7D32;
}

.log-date {
  font-size: 22rpx;
  color: #999;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-btn.primary {
  background: #2E7D32;
  color: #fff;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
