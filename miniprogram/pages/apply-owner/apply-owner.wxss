/* 塘主入驻申请页面 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.form-item .required {
  color: #ff5252;
}

.form-item .input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.form-item .picker {
  font-size: 28rpx;
  color: #333;
}

.location-input {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.location-input .input {
  text-align: right;
  color: #2E7D32;
}

.upload-area {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.upload-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 40rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 8rpx;
}

.upload-box .icon {
  font-size: 60rpx;
  color: #2E7D32;
  margin-bottom: 10rpx;
}

.upload-box .label {
  font-size: 24rpx;
  color: #999;
}

.license-img {
  max-width: 300rpx;
  max-height: 200rpx;
  border-radius: 8rpx;
}

.tips {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

.submit-section {
  margin-top: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn:active {
  opacity: 0.8;
}
