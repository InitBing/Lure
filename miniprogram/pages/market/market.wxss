/* 二手市场页面 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
}

.search-input .icon {
  margin-right: 10rpx;
}

.search-input .placeholder {
  color: #999;
  font-size: 28rpx;
}

.categories {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 10rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.category-item.active {
  background: #2E7D32;
  color: #fff;
}

.item-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.item-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.item-card .main-img {
  width: 100%;
  height: 300rpx;
}

.item-info {
  padding: 16rpx;
}

.item-info .title {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-info .brand {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.item-info .price {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.item-info .current {
  font-size: 32rpx;
  color: #ff5252;
  font-weight: bold;
}

.item-info .original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.item-info .meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.item-info .seller {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.item-info .avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.item-info .name {
  font-size: 22rpx;
  color: #666;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background: #2E7D32;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(46,125,50,0.4);
}
