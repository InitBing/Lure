/* 黑坑详情页 */
.container {
  padding-bottom: 120rpx;
  background: #f5f5f5;
}

.banner {
  width: 100%;
  height: 400rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.card {
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.info-card .pond-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.info-card .pond-address {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.info-card .pond-address .icon {
  margin-right: 8rpx;
}

.info-card .pond-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.info-card .pond-tags .tag {
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  color: #2E7D32;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.info-card .rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-card .stars {
  font-size: 28rpx;
}

.info-card .score {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff9800;
}

.info-card .count {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title .more {
  font-size: 24rpx;
  color: #2E7D32;
  font-weight: normal;
}

.owner-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.owner-info .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.owner-detail {
  flex: 1;
}

.owner-detail .owner-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.owner-detail .owner-stats {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.contact-btn {
  padding: 12rpx 30rpx;
  background: #2E7D32;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.facility-list, .fish-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.facility-item, .fish-item {
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.rules-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.event-item {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.event-type {
  padding: 4rpx 12rpx;
  background: #667eea;
  color: #fff;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.event-status {
  padding: 4rpx 12rpx;
  background: #e0e0e0;
  color: #666;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.event-status.active {
  background: #e8f5e9;
  color: #2E7D32;
}

.event-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.event-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.event-participants {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

.event-participants .prize {
  color: #ff9800;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-btn.primary {
  background: #2E7D32;
  color: #fff;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
