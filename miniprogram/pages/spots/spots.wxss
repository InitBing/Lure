/* 钓点页面 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
}

.search-input .icon {
  margin-right: 10rpx;
}

.search-input .placeholder {
  color: #999;
  font-size: 28rpx;
}

.mode-switch {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.mode-btn.active {
  background: #2E7D32;
  color: #fff;
}

.filters {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.filter-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.spot-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.spot-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.spot-item .cover {
  width: 240rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.spot-item .info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.spot-item .name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.spot-item .location {
  font-size: 24rpx;
  color: #999;
  margin: 8rpx 0;
}

.spot-item .tags {
  display: flex;
  gap: 10rpx;
  margin: 8rpx 0;
}

.spot-item .tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #e8f5e9;
  color: #2E7D32;
  border-radius: 4rpx;
}

.spot-item .meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.map-container {
  height: 1200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 100%;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background: #2E7D32;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(46,125,50,0.4);
}
