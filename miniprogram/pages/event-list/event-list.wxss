/* 活动列表页面 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.filters {
  display: flex;
  gap: 10rpx;
  padding: 20rpx;
  background: #fff;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background: #2E7D32;
  color: #fff;
}

.list-scroll {
  flex: 1;
  padding: 20rpx;
}

.event-card {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.event-card .cover {
  width: 240rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.event-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.event-type {
  padding: 4rpx 12rpx;
  background: #667eea;
  color: #fff;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-tag {
  padding: 4rpx 12rpx;
  background: #e0e0e0;
  color: #666;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-tag.active {
  background: #e8f5e9;
  color: #2E7D32;
}

.event-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.pond-name {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.event-meta {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee {
  font-size: 30rpx;
  color: #ff5252;
  font-weight: bold;
}

.participants {
  font-size: 22rpx;
  color: #999;
}

.prize {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: bold;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
