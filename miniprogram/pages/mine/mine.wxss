/* 个人中心页面 */
.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #1b5e20 100%);
  color: #fff;
}

.user-header .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-header .user-info {
  flex: 1;
  margin-left: 30rpx;
}

.user-header .nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-header .region {
  font-size: 26rpx;
  opacity: 0.8;
}

.user-header .edit-btn,
.user-header .login-btn {
  padding: 12rpx 30rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  font-size: 26rpx;
}

.stats {
  display: flex;
  background: #fff;
  margin: 30rpx;
  padding: 30rpx 0;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-right: none;
}

.stat-item .value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.stat-item .label {
  font-size: 24rpx;
  color: #999;
}

.menu-section {
  margin: 30rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item .icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-item .label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-item .arrow {
  font-size: 40rpx;
  color: #ccc;
}

.menu-item .badge {
  background: #ff5252;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
}

.logout-btn {
  margin: 30rpx;
  padding: 30rpx;
  background: #fff;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #ff5252;
}
