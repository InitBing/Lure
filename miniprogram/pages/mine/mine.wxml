<!-- 个人中心页面 -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" />
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || '点击登录'}}</view>
      <view class="region" wx:if="{{userInfo.region}}">📍 {{userInfo.region}}</view>
    </view>
    <view class="edit-btn" bindtap="goProfile" wx:if="{{isLogin}}">编辑</view>
    <view class="login-btn" bindtap="login" wx:else>登录</view>
  </view>

  <!-- 统计数据 -->
  <view class="stats" wx:if="{{isLogin}}">
    <view class="stat-item">
      <view class="value">{{stats.log_count || 0}}</view>
      <view class="label">作钓</view>
    </view>
    <view class="stat-item">
      <view class="value">{{stats.catch_count || 0}}</view>
      <view class="label">渔获</view>
    </view>
    <view class="stat-item">
      <view class="value">{{stats.follower_count || 0}}</view>
      <view class="label">粉丝</view>
    </view>
    <view class="stat-item">
      <view class="value">{{stats.following_count || 0}}</view>
      <view class="label">关注</view>
    </view>
  </view>

  <!-- 我的内容 -->
  <view class="menu-section">
    <view class="section-title">我的内容</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goMyLogs">
        <text class="icon">📝</text>
        <text class="label">作钓记录</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goMyItems">
        <text class="icon">🛒</text>
        <text class="label">二手商品</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goMyFavorites">
        <text class="icon">⭐</text>
        <text class="label">我的收藏</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 消息与通知 -->
  <view class="menu-section">
    <view class="section-title">消息与通知</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goMessages">
        <text class="icon">💬</text>
        <text class="label">私信</text>
        <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goNotifications">
        <text class="icon">🔔</text>
        <text class="label">通知</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-section">
    <view class="section-title">设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goPrivacy">
        <text class="icon">🔒</text>
        <text class="label">隐私设置</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goFeedback">
        <text class="icon">📢</text>
        <text class="label">反馈与帮助</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goAbout">
        <text class="icon">ℹ️</text>
        <text class="label">关于我们</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout" wx:if="{{isLogin}}">
    退出登录
  </view>
</view>
