/* 二手商品详情页面 */
.container {
  padding-bottom: 120rpx;
  background: #f5f5f5;
}

.banner {
  width: 100%;
  height: 600rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.card {
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.info-card .title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.info-card .price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.info-card .price {
  font-size: 40rpx;
  color: #ff5252;
  font-weight: bold;
}

.info-card .original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.info-card .condition-tag {
  padding: 6rpx 16rpx;
  background: #e8f5e9;
  color: #2E7D32;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.info-card .brand {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.info-card .meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.seller-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.seller-info .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.seller-detail {
  flex: 1;
}

.seller-detail .nickname {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.seller-detail .stats {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.chat-btn {
  padding: 12rpx 30rpx;
  background: #2E7D32;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.detail-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row .label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
}

.detail-row .value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.desc {
  margin-top: 16rpx;
}

.desc .label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-btn.primary {
  background: #2E7D32;
  color: #fff;
}
