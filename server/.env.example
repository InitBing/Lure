# LureBin 服务器环境配置

# 基础配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lurebin

# Redis 配置 (可选，用于限流和缓存)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# 微信小程序配置
WECHAT_APP_ID=wx_xxxxxxxxxxxxxx
WECHAT_APP_SECRET=your_wechat_app_secret

# 微信支付配置
WECHAT_PAY_MCHID=your_merchant_id
WECHAT_PAY_KEY=your_wechat_pay_key
WECHAT_PAY_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_PAY_KEY_PATH=/path/to/apiclient_key.pem

# 腾讯云 COS 配置 (图片/视频存储)
COS_BUCKET=your-bucket-123456
COS_REGION=ap-guangzhou
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BASE_URL=https://cos.lurebin.com

# 腾讯地图配置 (可选)
TENCENT_MAP_KEY=your_map_key

# 阿里云短信配置 (可选，用于验证码)
ALIYUN_SMS_ACCESS_KEY=your_access_key
ALIYUN_SMS_ACCESS_SECRET=your_access_secret
ALIYUN_SMS_SIGN_NAME=your_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_template_code

# 支付宝配置 (可选)
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 邮件配置 (可选，用于通知)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=LureBin <noreply@lurebin.com>

# 管理后台配置
ADMIN_SESSION_SECRET=your_admin_session_secret
ADMIN_TOKEN_EXPIRES_IN=24h

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/lurebin
